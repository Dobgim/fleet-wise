# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI (server-side only — never expose in the browser) ---
OPENAI_API_KEY=
# Optional: override the model (default gpt-4o-mini)
OPENAI_MODEL=

# --- Maintenance reminder emails (daily cron) ---
# Service role key: Supabase dashboard > Settings > API. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Any long random string; Vercel sends it as the cron Authorization header.
CRON_SECRET=
# One email provider. Brevo works without owning a domain; Resend needs one.
BREVO_API_KEY=
RESEND_API_KEY=
# Sender address shown to users (must be a verified sender with your provider).
EMAIL_FROM=
# Used for links and the logo inside emails.
NEXT_PUBLIC_SITE_URL=https://fleet-wise-delta.vercel.app

# --- Stripe payments ---
# Secret key: Stripe dashboard > Developers > API keys (starts sk_live_ / sk_test_).
STRIPE_SECRET_KEY=
# Webhook signing secret from the endpoint you create (starts whsec_).
STRIPE_WEBHOOK_SECRET=
# Price IDs (Stripe > Products): create a $20/mo and a $100/mo recurring price.
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
# Flip to "true" once the four values above are set — turns on real checkout
# in the UI instead of the simulated plan switch. Safe to expose (public).
NEXT_PUBLIC_STRIPE_ENABLED=

# --- Stripe (step 8) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend (step 9) ---
RESEND_API_KEY=

# --- PostHog (step 10) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Feature flags ---
NEXT_PUBLIC_ENABLE_RECEIPT_UPLOADS=false
